{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "*.test.ts"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "!src/**/*.integration.test.ts"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": ["src/**"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
