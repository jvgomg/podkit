{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "!src/**/*.test.ts",
        "!src/__tests__/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "outputs": ["dist/**"]
    },
    "@podkit/libgpod-node#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "!src/**/*.test.ts",
        "!src/__tests__/**",
        "native/**",
        "binding.gyp",
        "package.json",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "outputs": ["dist/**", "build/**"]
    },
    "@podkit/ipod-web#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "!src/**/*.test.ts",
        "!src/__tests__/**",
        "index.html",
        "vite.config.ts",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["dist/**"]
    },
    "@podkit/virtual-ipod-app#build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "index.html", "vite.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "@podkit/docs-site#test": { "dependsOn": [] },
    "@podkit/docs-site#test:unit": { "dependsOn": [] },
    "@podkit/docs-site#test:integration": { "dependsOn": [] },
    "@podkit/demo#test": { "dependsOn": [] },
    "@podkit/demo#test:unit": { "dependsOn": [] },
    "@podkit/demo#test:integration": { "dependsOn": [] },
    "@podkit/demo#build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "!src/**/*.test.ts", "build.ts", "package.json", "tsconfig.json"],
      "outputs": ["bin/**"]
    },
    "test": {
      "dependsOn": ["test:unit", "test:integration"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "!src/**/*.integration.test.ts", "!src/**/*.e2e.test.ts"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": ["src/**"],
      "outputs": []
    },
    "@podkit/e2e-tests#test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**"],
      "outputs": []
    },
    "@podkit/e2e-tests#test:unit": { "dependsOn": [] },
    "@podkit/e2e-tests#test:integration": { "dependsOn": [] },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "compile": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "!src/**/*.test.ts", "!src/__tests__/**", "package.json"],
      "outputs": ["bin/**"]
    },
    "record": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "build.ts", "demo.tape", "run.sh", "package.json"],
      "outputs": ["demo.gif"]
    },
    "@podkit/ipod-db#generate-fixtures": {
      "dependsOn": ["^build"],
      "inputs": ["fixtures/generate.ts"],
      "outputs": ["fixtures/databases/**"],
      "cache": true
    },
    "@podkit/ipod-db#test:unit": {
      "dependsOn": ["build", "generate-fixtures"],
      "inputs": ["src/**", "__tests__/**", "!src/**/*.integration.test.ts"],
      "outputs": []
    },
    "@podkit/ipod-db#test:integration": {
      "dependsOn": ["build", "generate-fixtures"],
      "inputs": ["src/**", "__tests__/**"],
      "outputs": []
    },
    "@podkit/test-fixtures#generate-fixtures": {
      "inputs": ["src/**"],
      "outputs": ["../../test/manual-collection/**"],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
