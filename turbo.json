{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**"]
    },
    "@podkit/docs-site#test": { "dependsOn": [] },
    "@podkit/docs-site#test:unit": { "dependsOn": [] },
    "@podkit/docs-site#test:integration": { "dependsOn": [] },
    "@podkit/demo#test": { "dependsOn": [] },
    "@podkit/demo#test:unit": { "dependsOn": [] },
    "@podkit/demo#test:integration": { "dependsOn": [] },
    "@podkit/demo#build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "build.ts", "package.json", "tsconfig.json"],
      "outputs": ["bin/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "*.test.ts"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "!src/**/*.integration.test.ts"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": ["src/**"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "compile": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json"],
      "outputs": ["bin/**"]
    },
    "record": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "build.ts", "demo.tape", "run.sh", "package.json"],
      "outputs": ["demo.gif"]
    },
    "clean": {
      "cache": false
    }
  }
}
