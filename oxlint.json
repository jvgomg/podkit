{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "nursery": "off",
    "restriction": "off",
    "no-unused-vars": "error",
    "no-console": "warn",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.integration.test.ts", "**/*.e2e.test.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/e2e-tests/src/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/podkit-cli/src/config/**/*.ts", "**/podkit-cli/src/output/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": ["node_modules", "dist", "*.d.ts", "backlog", "docs"]
}
