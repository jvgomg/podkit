{
  "name": "podkit",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "podkit": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "bun build src/main.ts --outdir dist --target node && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@podkit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
