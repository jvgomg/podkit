{
  "name": "@podkit/e2e-tests",
  "version": "0.0.0",
  "description": "End-to-end tests for the podkit CLI",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun run src/scripts/run-parallel.ts",
    "test:serial": "bun test",
    "test:dummy": "IPOD_TARGET=dummy bun run src/scripts/run-parallel.ts",
    "test:real": "IPOD_TARGET=real bun test",
    "test:subsonic": "SUBSONIC_E2E=1 bun test src/workflows/subsonic-sync.e2e.test.ts",
    "preflight": "bun run src/helpers/preflight.ts",
    "cleanup:docker": "bun run src/scripts/cleanup-containers.ts",
    "cleanup:docker:force": "bun run src/scripts/cleanup-containers.ts --force",
    "cleanup:docker:list": "bun run src/scripts/cleanup-containers.ts --list",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@podkit/compatibility": "workspace:*",
    "@podkit/gpod-testing": "workspace:*",
    "podkit": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
